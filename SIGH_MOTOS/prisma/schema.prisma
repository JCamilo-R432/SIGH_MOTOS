generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum MovementType {
  ENTRY           // Compra / recepción de mercancía
  EXIT            // Salida por venta o despacho
  ADJUSTMENT_POS  // Ajuste positivo (conteo físico)
  ADJUSTMENT_NEG  // Ajuste negativo (conteo físico)
  MERMA           // Pérdida / daño irrecuperable
  RETURN          // Devolución de cliente o proveedor
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
  CREDIT  // Venta/compra a crédito — genera CxC o CxP
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PurchaseOrderStatus {
  PENDING             // Creada, sin recibir nada
  PARTIALLY_RECEIVED  // Se recibió parte
  RECEIVED            // Completamente recibida
  CANCELLED           // Cancelada (solo desde PENDING)
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 1 — INVENTARIO
// ═══════════════════════════════════════════════════════════════════════════

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  logoUrl   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("brands")
}

model Category {
  id               String    @id @default(cuid())
  name             String    @unique
  slug             String    @unique
  codePrefix       String    @db.VarChar(6)
  marginPercentage Decimal   @default(30.00) @db.Decimal(5, 2)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products         Product[]

  @@map("categories")
}

model Product {
  id              String   @id @default(cuid())

  skuInternal     String   @unique
  barcodeExternal String?  @unique
  partNumberOEM   String

  brandId         String
  categoryId      String
  brand           Brand    @relation(fields: [brandId], references: [id])
  category        Category @relation(fields: [categoryId], references: [id])

  nameCommercial   String
  descriptionTech  String?
  compatibleModels Json    @default("[]")
  imageKey         String?

  locationBin     String

  costPriceAvg    Decimal  @default(0.00) @db.Decimal(12, 4) // 4 decimales para costo promedio ponderado
  salePriceBase   Decimal  @default(0.00) @db.Decimal(12, 2)
  taxRate         Decimal  @default(19.00) @db.Decimal(5, 2)

  stockQuantity   Int      @default(0)
  minStockLevel   Int      @default(5)
  maxStockLevel   Int?

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  movements           InventoryMovement[]
  saleItems           SaleItem[]
  purchaseOrderItems  PurchaseOrderItem[] // ← relación con Módulo 3

  @@index([skuInternal])
  @@index([barcodeExternal])
  @@index([brandId, categoryId])
  @@map("products")
}

model InventoryMovement {
  id                String       @id @default(cuid())
  productId         String
  product           Product      @relation(fields: [productId], references: [id])

  type              MovementType
  quantity          Int
  unitCostAtMoment  Decimal      @db.Decimal(12, 4)

  referenceDoc      String?
  reason            String?
  performedByUserId String?

  timestamp         DateTime     @default(now())

  @@index([productId, timestamp])
  @@map("inventory_movements")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 2 — VENTAS / POS
// ═══════════════════════════════════════════════════════════════════════════

model Customer {
  id                   String   @id @default(cuid())
  name                 String
  phone                String?
  email                String?
  identificationNumber String?  @unique
  address              String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sales              Sale[]
  accountsReceivable AccountReceivable[]

  @@index([phone])
  @@index([identificationNumber])
  @@map("customers")
}

model Sale {
  id             String        @id @default(cuid())
  saleNumber     String        @unique

  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])

  userId         String

  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0.00) @db.Decimal(12, 2)
  taxAmount      Decimal       @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)

  paymentMethod  PaymentMethod
  status         SaleStatus    @default(COMPLETED)
  notes          String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items             SaleItem[]
  accountReceivable AccountReceivable?

  @@index([saleNumber])
  @@index([customerId])
  @@index([userId])
  @@index([status, createdAt])
  @@map("sales")
}

model SaleItem {
  id      String @id @default(cuid())
  saleId  String
  sale    Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productNameSnapshot String
  skuSnapshot         String

  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)
  discountPerItem Decimal @default(0.00) @db.Decimal(12, 2)
  lineTotal       Decimal @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 3 — COMPRAS Y PROVEEDORES
// ═══════════════════════════════════════════════════════════════════════════

model Supplier {
  id            String   @id @default(cuid())
  name          String
  nit           String?  @unique
  phone         String?
  email         String?
  address       String?
  contactPerson String?
  // Condiciones de pago acordadas, ej: "30 días", "Contado", "15 días"
  paymentTerms  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  accountsPayable AccountPayable[]

  @@index([nit])
  @@index([name])
  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  // Consecutivo legible: OC-2026-00001
  orderNumber String              @unique

  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id])

  // Responsable de la compra (vinculado al módulo de Auth futuro)
  userId      String

  status      PurchaseOrderStatus @default(PENDING)

  subtotal    Decimal             @db.Decimal(12, 2)
  taxAmount   Decimal             @db.Decimal(12, 2)
  totalAmount Decimal             @db.Decimal(12, 2)

  // Fecha estimada de llegada (planificación)
  expectedDate  DateTime?
  // Fecha real de recepción completa (se asigna cuando status = RECEIVED)
  receivedDate  DateTime?

  notes       String?

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items          PurchaseOrderItem[]
  accountPayable AccountPayable?

  @@index([orderNumber])
  @@index([supplierId])
  @@index([status, createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Snapshot del producto al momento de crear la OC
  productNameSnapshot String
  skuSnapshot         String

  quantityOrdered  Int
  // Acumulado de recepciones parciales. quantityOrdered - quantityReceived = pendiente
  quantityReceived Int     @default(0)

  // Costo acordado con el proveedor para esta OC
  unitCost  Decimal @db.Decimal(12, 4)
  // unitCost * quantityOrdered
  lineTotal Decimal @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 5 — USUARIOS, SEGURIDAD Y AUDITORÍA (RBAC)
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs             AuditLog[]
  openedRegisters       CashRegister[]         @relation("CashRegisterOpenedBy")
  closedRegisters       CashRegister[]         @relation("CashRegisterClosedBy")
  financialTransactions FinancialTransaction[] @relation("FinTxPerformedBy")
  paymentRecords        PaymentRecord[]        @relation("PaymentPerformedBy")

  @@index([email])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   Json     @default("{}")
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 6 — GESTIÓN FINANCIERA, CAJA Y CUENTAS POR COBRAR/PAGAR
// ═══════════════════════════════════════════════════════════════════════════

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum TransactionType {
  INCOME            // Entrada genérica (ej: venta de contado)
  EXPENSE           // Gasto operativo (luz, agua, almuerzo)
  WITHDRAWAL        // Retiro del dueño
  DEPOSIT           // Depósito bancario desde caja
  PAYMENT_RECEIVED  // Abono de cliente a su deuda (CxC)
  PAYMENT_MADE      // Pago a proveedor (CxP)
}

enum AccountStatus {
  PENDING          // Deuda sin ningún abono
  PARTIALLY_PAID   // Con abonos pero saldo pendiente
  PAID             // Saldada completamente
  OVERDUE          // Vencida (dueDate superado y no pagada)
}

model CashRegister {
  id                     String              @id @default(cuid())
  openedByUserId         String
  closedByUserId         String?
  openedBy               User                @relation("CashRegisterOpenedBy", fields: [openedByUserId], references: [id])
  closedBy               User?               @relation("CashRegisterClosedBy", fields: [closedByUserId], references: [id])

  openingBalance         Decimal             @db.Decimal(12, 2)
  closingBalance         Decimal?            @db.Decimal(12, 2)  // Conteo físico al cerrar
  expectedClosingBalance Decimal?            @db.Decimal(12, 2)  // Calculado por el sistema
  difference             Decimal?            @db.Decimal(12, 2)  // closing - expected (negativo = falta plata)

  status                 CashRegisterStatus  @default(OPEN)
  openedAt               DateTime            @default(now())
  closedAt               DateTime?
  notes                  String?

  transactions FinancialTransaction[]

  @@index([status])
  @@index([openedByUserId])
  @@map("cash_registers")
}

model FinancialTransaction {
  id              String          @id @default(cuid())
  cashRegisterId  String
  cashRegister    CashRegister    @relation(fields: [cashRegisterId], references: [id])

  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  description     String
  category        String          // "Venta", "Pago Proveedor", "Servicios", "Retiro Dueño"

  referenceType   String?         // "SALE", "PURCHASE_ORDER", "PAYMENT_RECORD"
  referenceId     String?         // UUID del documento origen

  paymentMethod   PaymentMethod   @default(CASH)

  performedByUserId String
  performedBy       User        @relation("FinTxPerformedBy", fields: [performedByUserId], references: [id])

  timestamp       DateTime        @default(now())

  @@index([cashRegisterId])
  @@index([type])
  @@index([timestamp])
  @@map("financial_transactions")
}

model AccountReceivable {
  id               String        @id @default(cuid())
  saleId           String        @unique
  sale             Sale          @relation(fields: [saleId], references: [id])
  customerId       String
  customer         Customer      @relation(fields: [customerId], references: [id])

  totalDebt        Decimal       @db.Decimal(12, 2)
  paidAmount       Decimal       @default(0.00) @db.Decimal(12, 2)
  remainingBalance Decimal       @db.Decimal(12, 2)

  dueDate          DateTime?
  status           AccountStatus @default(PENDING)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  payments         PaymentRecord[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_receivable")
}

model AccountPayable {
  id               String        @id @default(cuid())
  purchaseOrderId  String        @unique
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  supplierId       String
  supplier         Supplier      @relation(fields: [supplierId], references: [id])

  totalDebt        Decimal       @db.Decimal(12, 2)
  paidAmount       Decimal       @default(0.00) @db.Decimal(12, 2)
  remainingBalance Decimal       @db.Decimal(12, 2)

  dueDate          DateTime?
  status           AccountStatus @default(PENDING)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  payments         PaymentRecord[]

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_payable")
}

model PaymentRecord {
  id                   String             @id @default(cuid())
  accountReceivableId  String?
  accountReceivable    AccountReceivable? @relation(fields: [accountReceivableId], references: [id])
  accountPayableId     String?
  accountPayable       AccountPayable?    @relation(fields: [accountPayableId], references: [id])

  amount               Decimal            @db.Decimal(12, 2)
  paymentMethod        PaymentMethod      @default(CASH)
  referenceDoc         String?            // Número de comprobante / recibo
  note                 String?

  performedByUserId    String
  performedBy          User               @relation("PaymentPerformedBy", fields: [performedByUserId], references: [id])

  timestamp            DateTime           @default(now())

  @@index([accountReceivableId])
  @@index([accountPayableId])
  @@map("payment_records")
}
