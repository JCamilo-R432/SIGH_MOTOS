generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum MovementType {
  ENTRY           // Compra / recepción de mercancía
  EXIT            // Salida por venta o despacho
  ADJUSTMENT_POS  // Ajuste positivo (conteo físico)
  ADJUSTMENT_NEG  // Ajuste negativo (conteo físico)
  MERMA           // Pérdida / daño irrecuperable
  RETURN          // Devolución de cliente o proveedor
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 1 — INVENTARIO
// ═══════════════════════════════════════════════════════════════════════════

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  logoUrl   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("brands")
}

model Category {
  id               String    @id @default(cuid())
  name             String    @unique
  slug             String    @unique
  codePrefix       String    @db.VarChar(6)
  marginPercentage Decimal   @default(30.00) @db.Decimal(5, 2)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products         Product[]

  @@map("categories")
}

model Product {
  id              String   @id @default(cuid())

  skuInternal     String   @unique
  barcodeExternal String?  @unique
  partNumberOEM   String

  brandId         String
  categoryId      String
  brand           Brand    @relation(fields: [brandId], references: [id])
  category        Category @relation(fields: [categoryId], references: [id])

  nameCommercial  String
  descriptionTech String?
  compatibleModels Json    @default("[]")
  imageKey        String?

  locationBin     String

  costPriceAvg    Decimal  @default(0.00) @db.Decimal(12, 2)
  salePriceBase   Decimal  @default(0.00) @db.Decimal(12, 2)
  taxRate         Decimal  @default(19.00) @db.Decimal(5, 2)

  stockQuantity   Int      @default(0)
  minStockLevel   Int      @default(5)
  maxStockLevel   Int?

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  movements       InventoryMovement[]
  saleItems       SaleItem[]           // ← relación con Módulo 2

  @@index([skuInternal])
  @@index([barcodeExternal])
  @@index([brandId, categoryId])
  @@map("products")
}

model InventoryMovement {
  id                String       @id @default(cuid())
  productId         String
  product           Product      @relation(fields: [productId], references: [id])

  type              MovementType
  quantity          Int
  unitCostAtMoment  Decimal      @db.Decimal(12, 2)

  referenceDoc      String?
  reason            String?
  performedByUserId String?

  timestamp         DateTime     @default(now())

  @@index([productId, timestamp])
  @@map("inventory_movements")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 2 — VENTAS / POS
// ═══════════════════════════════════════════════════════════════════════════

model Customer {
  id                   String   @id @default(cuid())
  name                 String
  phone                String?
  email                String?
  // NIT o Cédula — único por cliente registrado
  identificationNumber String?  @unique
  address              String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sales Sale[]

  @@index([phone])
  @@index([identificationNumber])
  @@map("customers")
}

model Sale {
  id             String        @id @default(cuid())
  // Consecutivo legible: VTA-2026-00001
  saleNumber     String        @unique

  // Cliente — nullable para "Cliente Genérico"
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])

  // Vendedor responsable (se vinculará al modelo User en el Módulo de Auth)
  userId         String

  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0.00) @db.Decimal(12, 2)
  taxAmount      Decimal       @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)

  paymentMethod  PaymentMethod
  status         SaleStatus    @default(COMPLETED)
  notes          String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items          SaleItem[]

  @@index([saleNumber])
  @@index([customerId])
  @@index([userId])
  @@index([status, createdAt])
  @@map("sales")
}

model SaleItem {
  id      String @id @default(cuid())
  saleId  String
  sale    Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Snapshots del producto en el momento de la venta.
  // Crítico: si el producto cambia de nombre/SKU o se elimina,
  // la factura histórica conserva los datos originales.
  productNameSnapshot String
  skuSnapshot         String

  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)
  discountPerItem Decimal @default(0.00) @db.Decimal(12, 2)
  // (unitPrice * quantity) - discountPerItem
  lineTotal       Decimal @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}
